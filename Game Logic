// Define the base points for actions based on your rules
const ACTION_REWARDS: Record<string, number> = {
  SCOUT: 100, // Taking picture, naming, labeling
  PHOTO_UPDATE: 5,
  SOCIALIZE: 8,
  FEED: 10,
  SHOWER: 50,
  MEDICAL: 70,
  HABITAT_CLEAN: 200,
  EVENT: 300,
};

export const RewardEngine = {
  // Calculate points with the 10m Synergy Bonus
  calculatePoints: (action: string, isFriendNearby: boolean): number => {
    const basePoints = ACTION_REWARDS[action] || 0;
    if (isFriendNearby) {
      return Math.floor(basePoints * 1.5); // 1.5x Multiplier
    }
    return basePoints;
  },

  // Math to check distance between two GPS coordinates (Haversine formula)
  getDistanceInMeters: (lat1: number, lon1: number, lat2: number, lon2: number): number => {
    const R = 6371e3; // Earth radius in meters
    const dLat = ((lat2 - lat1) * Math.PI) / 180;
    const dLon = ((lon2 - lon1) * Math.PI) / 180;
    const a =
      Math.sin(dLat / 2) * Math.sin(dLat / 2) +
      Math.cos((lat1 * Math.PI) / 180) * Math.cos((lat2 * Math.PI) / 180) *
      Math.sin(dLon / 2) * Math.sin(dLon / 2);
    const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    return R * c;
  },

  // Prevent duplicate animal registrations within 50 meters
  isDuplicateNode: (newLat: number, newLng: number, existingNodes: any[]): boolean => {
    for (const node of existingNodes) {
      const distance = RewardEngine.getDistanceInMeters(newLat, newLng, node.latitude, node.longitude);
      if (distance <= 50) {
        return true; // Too close! Flag for audit.
      }
    }
    return false;
  }
};
